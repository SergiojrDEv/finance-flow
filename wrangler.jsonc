{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "finance-flow",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
